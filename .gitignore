# Dependencias (cualquier nivel; no ejecutar `npm install` en la raíz del monorepo)
node_modules/

# --- Frontend (Astro / Vite) ---
frontend/dist/
frontend/.output/
# Tipos y caché generados por Astro (en frontend o si el editor ejecuta desde la raíz)
.astro/
frontend/.astro/

# --- Backend (Node / TypeScript) ---
backend/dist/

# Variables de entorno (secretos y overrides locales)
.env
.env.*
!.env.example
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# Tests y cobertura
coverage/
.nyc_output/

# Cachés y artefactos de build
.cache/
.parcel-cache/
*.tsbuildinfo
.turbo/

# Salidas de build genéricas (por si se generan fuera de frontend|backend)
/dist/
.output/
