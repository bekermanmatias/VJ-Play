# Servidor
PORT=4000
NODE_ENV=development

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=service_role_o_anon_según_corresponda

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret
R2_BUCKET_NAME=varela-junior-media
# Endpoint S3 para R2 (sin https:// en algunos SDKs; el código arma la URL si falta)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# URL pública opcional (Custom Domain o R2 public bucket) para prefijar enlaces devueltos al cliente
R2_PUBLIC_BASE_URL=

# FFmpeg (opcional: ruta al binario si no está en PATH)
# FFMPEG_PATH=
# FFPROBE_PATH=

# Marca de agua (PNG con transparencia). Si está vacío, el snap se sube sin composite
WATERMARK_PNG_PATH=

# RTSP por defecto para pruebas (las rutas pueden sobreescribir con body.sourceUrl)
DEFAULT_RTSP_URL=rtsp://usuario:clave@ip-camara:554/stream
