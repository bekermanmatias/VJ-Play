# Servidor
PORT=4000
NODE_ENV=development

# Rutas admin del API (header x-admin-secret). En frontend/.env usar PUBLIC_REPLAY_ADMIN_SECRET con el mismo valor.
# ADMIN_SECRET=

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=service_role_o_anon_según_corresponda

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret
R2_BUCKET_NAME=varela-junior-media
# Endpoint S3 para R2 (sin https:// en algunos SDKs; el código arma la URL si falta)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# URL pública opcional (Custom Domain o R2 public bucket). Debe coincidir con el prefijo de replay_assets.video_url para poder firmar descargas del partido completo sin pasar el archivo por el servidor.
R2_PUBLIC_BASE_URL=

# Validez de la URL firmada GET para descarga del partido completo (60–86400 segundos). Solo aplica si video_url usa el mismo origen que R2_PUBLIC_BASE_URL.
# REPLAY_FULL_VIDEO_PRESIGN_EXPIRES_SECONDS=900

# FFmpeg (opcional: ruta al binario si no está en PATH)
# FFMPEG_PATH=
# FFPROBE_PATH=

# Marca de agua para descargas (PNG con transparencia recomendado). Se ubica centrada en el borde inferior.
# Si está vacío, los clips y el partido completo se descargan sin marca.
# Ejemplos:
#   Windows -> WATERMARK_PNG_PATH=C:\Users\beker\OneDrive\Escritorio\Repositorios\VJ Play\backend\assets\watermark.png
#   Linux/Mac -> WATERMARK_PNG_PATH=/srv/vj-play/assets/watermark.png
WATERMARK_PNG_PATH=
# X = centro horizontal. BOTTOM = borde inferior del PNG (% desde arriba; subir = más abajo).
# WATERMARK_X_PERCENT=50
# WATERMARK_BOTTOM_PERCENT=93
# WATERMARK_WIDTH_PERCENT=44
# WATERMARK_MAX_HEIGHT_PERCENT=42

# RTSP por defecto para pruebas (las rutas pueden sobreescribir con body.sourceUrl)
DEFAULT_RTSP_URL=rtsp://usuario:clave@ip-camara:554/stream

# Duración de cada turno de grabación en segundos (3600 = 1 h, 5400 = 1 h 30). Debe coincidir con la fila en Supabase o con PUBLIC_REPLAY_SHIFT_DURATION_SECONDS en el front.
# RECORDING_SHIFT_DURATION_SECONDS=3600
# Fallback de ventana horaria si no hay fila en replay_shift_settings (mismos significados que en el front).
# RECORDING_SHIFTS_WINDOW_START_HOUR=8
# RECORDING_SHIFTS_WINDOW_END_HOUR=24
