# Servidor
PORT=4000
NODE_ENV=development

# Replays con código (pago manual en el club)
# Secreto para firmar la sesión tras validar el código (min. 16 caracteres recomendado)
JWT_SESSION_SECRET=cambiame_por_un_secreto_largo_y_aleatorio
# TTL de la sesión en segundos (por defecto 86400 = 24 h)
# REPLAY_SESSION_TTL_SECONDS=86400
# Orígenes permitidos CORS (coma separada). Por defecto localhost Astro/Vite.
# CORS_ORIGINS=http://localhost:4321,https://varelajunior.com.ar
# Fallback si no hay fila en replay_assets (demo)
# REPLAY_FALLBACK_VIDEO_URL=
# REPLAY_FALLBACK_POSTER_URL=
# Solo desarrollo: códigos en texto plano JSON (NO usar en producción)
# DEV_MATCH_ACCESS=[{"matchKey":"cancha-1|2025-05-05|09:00","code":"DEMO1234"}]
# Opcional: alta de códigos vía POST /api/replays/access/codes con header x-admin-secret
# ADMIN_SECRET=

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=service_role_o_anon_según_corresponda

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret
R2_BUCKET_NAME=varela-junior-media
# Endpoint S3 para R2 (sin https:// en algunos SDKs; el código arma la URL si falta)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# URL pública opcional (Custom Domain o R2 public bucket) para prefijar enlaces devueltos al cliente
R2_PUBLIC_BASE_URL=

# FFmpeg (opcional: ruta al binario si no está en PATH)
# FFMPEG_PATH=
# FFPROBE_PATH=

# Marca de agua (PNG con transparencia). Si está vacío, el snap se sube sin composite
WATERMARK_PNG_PATH=

# RTSP por defecto para pruebas (las rutas pueden sobreescribir con body.sourceUrl)
DEFAULT_RTSP_URL=rtsp://usuario:clave@ip-camara:554/stream
