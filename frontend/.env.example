# URL base del API (sin barra final). SIEMPRE con http:// o https://.
# Desarrollo local (backend en :4000, Supabase/R2 en backend/.env):
PUBLIC_REPLAY_API_BASE=http://localhost:4000
# Producción (ejemplo):
# PUBLIC_REPLAY_API_BASE=https://vj-play-production.up.railway.app

# Igual que ADMIN_SECRET del backend (queda en el bundle JS del cliente).
# PUBLIC_REPLAY_ADMIN_SECRET=

# Botón "Pedir código por WhatsApp" (link wa.me con texto prellenado opcional).
# PUBLIC_REPLAY_WHATSAPP_URL=https://wa.me/5491112345678?text=Hola%2C%20quiero%20el%20código%20para%20ver%20mi%20replay

# Turnos: primero la API lee `replay_shift_settings` en Supabase; si falla, estos valores públicos (build).
# PUBLIC_REPLAY_SHIFT_DURATION_SECONDS=3600
# Ventana horaria del listado (primer inicio y hora tope de fin del último turno).
# PUBLIC_REPLAY_SHIFTS_WINDOW_START_HOUR=8
# PUBLIC_REPLAY_SHIFTS_WINDOW_END_HOUR=24
