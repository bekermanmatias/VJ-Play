---
import type { DeportePageData } from "@/data/deportes";

interface Props {
  data: DeportePageData;
}

const { data } = Astro.props;

const hasSchedule =
  data.scheduleTitle && data.scheduleItems && data.scheduleItems.length > 0;

const phoneList =
  data.contactPhones && data.contactPhones.length > 0
    ? data.contactPhones
    : data.contactPhone && data.contactPhoneHref
      ? [{ phone: data.contactPhone, phoneHref: data.contactPhoneHref }]
      : [];

const hasContact = phoneList.length > 0;
const hasWhatsapp = data.whatsappUrl.trim() !== "";
const hasInstagram = data.instagramUrl.trim() !== "";
---

<section
  class="grid min-h-[calc(100dvh-8.25rem)] w-full grid-cols-1 lg:grid-cols-2 lg:min-h-[520px]"
    aria-labelledby="deporte-title"
  >
    <div
      class="flex min-h-[420px] flex-col justify-between bg-slate-900 px-6 py-12 text-slate-200 sm:px-10 lg:min-h-0 lg:px-14 xl:px-16 lg:py-16"
    >
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-vj-green">Deportes</p>
        <h1
          id="deporte-title"
          class="mt-3 font-display text-5xl font-normal uppercase leading-[0.95] tracking-wide text-white sm:text-6xl xl:text-7xl"
        >
          {data.title}
        </h1>

        <div class="mt-8 max-w-xl space-y-4 text-sm leading-relaxed text-slate-300 sm:text-base">
          {data.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>

        {
          hasSchedule && (
            <div class="mt-8 max-w-xl">
              <p class="text-sm font-bold uppercase tracking-wide text-white">{data.scheduleTitle}</p>
              <ul class="mt-3 space-y-2">
                {data.scheduleItems!.map((item) => (
                  <li class="flex items-center gap-3 text-sm text-slate-300 sm:text-base">
                    <span
                      class="inline-flex h-2.5 w-2.5 shrink-0 rounded-full bg-vj-green"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>

      <div class="mt-10 max-w-xl space-y-5 border-t border-slate-700 pt-8">
        {
          hasContact && (
            <div class="text-sm sm:text-base">
              {data.contactLabel && (
                <p class="text-slate-400">{data.contactLabel}</p>
              )}
              <ul class="mt-1 flex flex-col gap-1">
                {phoneList.map((p) => (
                  <li class="flex items-baseline gap-2">
                    {p.name && (
                      <span class="text-slate-400">{p.name}</span>
                    )}
                    <a
                      href={p.phoneHref}
                      class="font-semibold text-sky-400 underline-offset-2 hover:underline"
                    >
                      {p.phone}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        <div class="flex flex-wrap gap-3">
          {
            hasWhatsapp ? (
              <a
                href={data.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-sm border border-slate-600 bg-slate-900/80 px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-white transition hover:border-vj-green hover:bg-vj-green/10"
              >
                <svg class="h-5 w-5 shrink-0 text-vj-green" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.05 4.91A10 10 0 0 0 4.96 19.07L4 22l3-.78a10 10 0 0 0 12.05-16.31ZM12 20.18a8.27 8.27 0 0 1-4.21-1.15l-.3-.18-1.78.46.48-1.74-.2-.31A8.18 8.18 0 1 1 12 20.18Zm4.5-6.13c-.25-.13-1.46-.72-1.69-.8-.23-.08-.4-.13-.56.13-.16.25-.64.8-.78.96-.14.16-.29.18-.54.06-.25-.13-1.04-.38-1.99-1.22-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.38-.43.13-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.13-.55-1.32-.75-1.81-.2-.48-.4-.41-.55-.42h-.47c-.16 0-.41.06-.63.31-.21.25-.83.81-.83 1.98 0 1.16.85 2.29.97 2.45.13.16 1.68 2.56 4.07 3.59.57.25 1.01.39 1.36.5.57.18 1.09.16 1.5.1.46-.07 1.46-.6 1.66-1.18.21-.58.21-1.07.14-1.18-.06-.11-.23-.17-.49-.3Z" />
                </svg>
                WhatsApp
              </a>
            ) : (
              <span
                class="inline-flex cursor-not-allowed items-center gap-2 rounded-sm border border-dashed border-slate-600 px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-slate-500"
                title="Completá whatsappUrl en src/data/deportes.ts"
              >
                WhatsApp
              </span>
            )
          }
          {
            hasInstagram ? (
              <a
                href={data.instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-sm border border-slate-600 bg-slate-900/80 px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-white transition hover:border-vj-green hover:bg-vj-green/10"
              >
                <svg class="h-5 w-5 shrink-0 text-vj-green" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.51.01-4.75.07-1.02.05-1.57.22-1.94.36-.49.19-.84.42-1.21.79-.37.37-.6.72-.79 1.21-.14.37-.31.92-.36 1.94-.06 1.24-.07 1.6-.07 4.75s.01 3.51.07 4.75c.05 1.02.22 1.57.36 1.94.19.49.42.84.79 1.21.37.37.72.6 1.21.79.37.14.92.31 1.94.36 1.24.06 1.6.07 4.75.07s3.51-.01 4.75-.07c1.02-.05 1.57-.22 1.94-.36.49-.19.84-.42 1.21-.79.37-.37.6-.72.79-1.21.14-.37.31-.92.36-1.94.06-1.24.07-1.6.07-4.75s-.01-3.51-.07-4.75c-.05-1.02-.22-1.57-.36-1.94a3.27 3.27 0 0 0-.79-1.21 3.27 3.27 0 0 0-1.21-.79c-.37-.14-.92-.31-1.94-.36C15.51 4.01 15.15 4 12 4Zm0 3.05a4.95 4.95 0 1 1 0 9.9 4.95 4.95 0 0 1 0-9.9Zm0 1.8a3.15 3.15 0 1 0 0 6.3 3.15 3.15 0 0 0 0-6.3Zm5.15-2.06a1.16 1.16 0 1 1 0 2.32 1.16 1.16 0 0 1 0-2.32Z" />
                </svg>
                Instagram
              </a>
            ) : (
              <span
                class="inline-flex cursor-not-allowed items-center gap-2 rounded-sm border border-dashed border-slate-600 px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-slate-500"
                title="Completá instagramUrl en src/data/deportes.ts"
              >
                Instagram
              </span>
            )
          }
        </div>
      </div>
    </div>

    <div class="relative min-h-[320px] bg-slate-900 sm:min-h-[400px] lg:min-h-0">
      <img
        src={data.imageSrc}
        alt={data.imageAlt}
        width={data.imageWidth}
        height={data.imageHeight}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
</section>
