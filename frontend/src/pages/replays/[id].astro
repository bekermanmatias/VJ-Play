---
import Layout from "@/layouts/Layout.astro";
import TopBar from "@/components/TopBar.astro";
import Navbar from "@/components/Navbar.astro";
import ReplayPartidoById from "@/components/replays/ReplayPartidoById";

export const prerender = false;

const apiBase = import.meta.env.PUBLIC_REPLAY_API_BASE ?? "";
const cinema = Astro.url.searchParams.get("cinema") === "1";
const idParam = Number.parseInt(Astro.params.id ?? "", 10);
const matchId = Number.isFinite(idParam) && idParam > 0 ? idParam : null;
---

<Layout title="Replay | Partido">
  {!cinema && <TopBar />}
  {!cinema && <Navbar />}

  <main class={cinema ? "min-h-dvh bg-black" : "min-h-[calc(100vh-7rem)] bg-white"}>
    {cinema ? (
      <ReplayPartidoById client:load apiBase={apiBase} cinema={cinema} matchId={matchId} />
    ) : (
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
        <ReplayPartidoById client:load apiBase={apiBase} cinema={cinema} matchId={matchId} />
      </div>
    )}
  </main>
</Layout>
