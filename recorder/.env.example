# ===================================================================
# Recorder service — variables de entorno
# Copiar a recorder/.env y completar.
# ===================================================================

# --- Supabase (service role: tiene que poder escribir replay_assets y recorder_heartbeat)
SUPABASE_URL=
SUPABASE_KEY=

# --- Cloudflare R2 (mismas creds que el backend)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# --- DVR Dahua (visto desde el VPS, a través del túnel WireGuard)
DVR_RTSP_USER=recorder
DVR_RTSP_PASSWORD=
DVR_HOST=192.168.88.10
DVR_RTSP_PORT=554
# Plantilla de URL: usar {channel} y {subtype}. Si una cancha tiene rtsp_url_override
# en la DB, esta plantilla se ignora para ese caso.
DVR_RTSP_URL_TEMPLATE=rtsp://{user}:{password}@{host}:{port}/cam/realmonitor?channel={channel}&subtype={subtype}

# --- Tenant (multi-club futuro)
TENANT_ID=cvj

# --- Segmentación
RECORDING_SEGMENT_SECONDS=3600
# Carpeta local donde FFmpeg escribe los segmentos antes de subirlos
RECORDING_LOCAL_BUFFER_DIR=/var/lib/vjplay-recorder
# Cuántas horas guardar el archivo local después de subir a R2 (0 = borrar inmediatamente)
RECORDING_LOCAL_RETENTION_HOURS=24

# --- Ventana horaria del club (horas locales)
RECORDING_SHIFTS_WINDOW_START_HOUR=9
RECORDING_SHIFTS_WINDOW_END_HOUR=24
RECORDING_TIMEZONE=America/Argentina/Buenos_Aires

# --- FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
# 'copy' (rápido, sin re-encode) o 'h264' (re-encode, más CPU pero unifica codec)
RECORDING_VIDEO_MODE=copy

# --- Heartbeat
RECORDER_HEARTBEAT_INTERVAL_SECONDS=30
RECORDER_HOST_LABEL=

# --- Log level
LOG_LEVEL=info
