---
interface Props {
  items?: string[];
}

const {
  items = [
    "Fútbol",
    "Básquet",
    "Tenis",
    "Vóley",
    "Natación",
    "Hockey",
    "Gimnasia",
  ],
} = Astro.props;

const loop = [...items, ...items];
---

<div
  class="relative -mt-10 sm:-mt-14 z-20 overflow-hidden bg-white shadow-md -skew-y-2"
  aria-hidden="true"
>
  <div class="skew-y-2">
    <div class="overflow-hidden whitespace-nowrap py-3 sm:py-4">
      <div class="vj-marquee-track inline-flex w-max">
        {
          loop.map((sport) => (
            <span class="inline-flex items-center px-4 sm:px-6 font-display text-2xl sm:text-3xl uppercase tracking-wider text-slate-900">
              {sport}
              <span class="ml-4 sm:ml-6 inline-block h-2 w-2 rounded-full bg-vj-green" />
            </span>
          ))
        }
      </div>
    </div>
  </div>
</div>
