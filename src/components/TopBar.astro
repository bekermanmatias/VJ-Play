---

<div
  class="bg-slate-900 text-slate-200 text-xs sm:text-sm border-b border-slate-800"
>
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-9 flex items-center justify-between gap-4"
  >
    <!-- Bloque Izquierdo: contacto -->
    <div class="flex items-center gap-4 sm:gap-6 truncate">
      <a
        href={phoneHref}
        class="flex items-center gap-1.5 hover:text-white transition-colors"
        aria-label={`Llamar al ${phone}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-3.5 h-3.5 shrink-0"
          aria-hidden="true"
        >
          <path
            d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.05-.24c1.16.39 2.42.6 3.71.6a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A18 18 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.29.21 2.55.6 3.71a1 1 0 0 1-.24 1.05l-2.24 2.03Z"
          ></path>
        </svg>
        <span class="hidden sm:inline">{phone}</span>
      </a>

      <a
        href={emailHref}
        class="flex items-center gap-1.5 hover:text-white transition-colors truncate"
        aria-label={`Escribir a ${email}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-3.5 h-3.5 shrink-0"
          aria-hidden="true"
        >
          <path
            d="M2 6.5A2.5 2.5 0 0 1 4.5 4h15A2.5 2.5 0 0 1 22 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-15A2.5 2.5 0 0 1 2 17.5v-11Zm2.7-.5 7.3 5.84L19.3 6H4.7Zm15.3 1.36-7.36 5.88a1 1 0 0 1-1.28 0L4 7.36V17.5c0 .28.22.5.5.5h15c.28 0 .5-.22.5-.5V7.36Z"
          ></path>
        </svg>
        <span class="truncate">{email}</span>
      </a>
    </div>

    <!-- Bloque Derecho: redes -->
    <div class="flex items-center gap-3 sm:gap-4">
      <ul class="hidden sm:flex items-center gap-3">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                aria-label={s.name}
                class="text-slate-300 hover:text-vj-green transition-colors block"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="w-3.5 h-3.5"
                  aria-hidden="true"
                >
                  <path d={s.path} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
