---
import Layout from "@/layouts/Layout.astro";
import TopBar from "@/components/TopBar.astro";
import Navbar from "@/components/Navbar.astro";
---

<Layout title="Tenis | VJ Play" description="Seccion de tenis en desarrollo.">
  <TopBar />
  <Navbar />

  <main class="mx-auto flex min-h-[calc(100dvh-7.25rem)] max-w-7xl items-center justify-center px-4 sm:px-6 lg:px-8">
    <section class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-vj-green">Deportes / Tenis</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">En desarrollo</h1>
      <p class="mx-auto mt-3 max-w-2xl text-base text-slate-600">
        Esta pagina se encuentra en desarrollo. Pronto vamos a cargar contenidos de esta disciplina.
      </p>
    </section>
  </main>
</Layout>
